		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.5.0",
		"eslint": "^10.1.0",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"lint-staged": "^16.4.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
